#!/usr/bin/env python3
"""
new-agent — scaffold a new Pilot Protocol service agent from the template.

Usage:
    ./new-agent <name> <port> "<description>" [--endpoint <name>]

Examples:
    ./new-agent weather-agent  8400 "Provides weather forecasts"
    ./new-agent sql-agent      8401 "Natural language SQL query assistant" --endpoint sql
    ./new-agent docs-agent     8402 "Searches and summarizes internal docs"

After scaffolding:
    1. Edit <name>/agent/prompts.py  — write the system prompt
    2. Edit <name>/agent/tools.py   — add tool functions
    3. cp _template/.env.example <name>/.env && edit with your API key
    4. ./service-agents/<name>/start.sh  to run the API
    5. Add to ~/.pilot/endpoints.yaml   (instructions printed below)
    6. Add a shell alias (instructions printed below)
"""

import argparse
import re
import shutil
import subprocess
import sys
from pathlib import Path

TEMPLATE_DIR = Path(__file__).parent / "_template"
SERVICE_AGENTS_DIR = Path(__file__).parent


def slugify(name: str) -> str:
    """Convert name to safe directory name."""
    return re.sub(r"[^a-z0-9-]", "-", name.lower()).strip("-")


def replace_in_file(path: Path, replacements: dict[str, str]) -> None:
    try:
        content = path.read_text()
        for old, new in replacements.items():
            content = content.replace(old, new)
        path.write_text(content)
    except (UnicodeDecodeError, PermissionError):
        pass  # skip binary files


def scaffold(name: str, port: int, description: str, endpoint: str) -> Path:
    slug = slugify(name)
    dest = SERVICE_AGENTS_DIR / slug

    if dest.exists():
        print(f"Error: '{dest}' already exists.", file=sys.stderr)
        sys.exit(1)

    # Copy template
    shutil.copytree(TEMPLATE_DIR, dest)

    # Replacements in all text files
    replacements = {
        "{{AGENT_NAME}}": name,
        "{{AGENT_PORT}}": str(port),
        "{{AGENT_DESCRIPTION}}": description,
        "{{ENDPOINT_NAME}}": endpoint,
    }
    for fpath in dest.rglob("*"):
        if fpath.is_file():
            replace_in_file(fpath, replacements)

    # Make start.sh executable
    (dest / "start.sh").chmod(0o755)

    return dest


def print_next_steps(name: str, slug: str, port: int, description: str, endpoint: str, dest: Path) -> None:
    tui_cmd = f"AGENT_NAME='{name}' AGENT_PORT={port} .venv/bin/python -m tui.app"

