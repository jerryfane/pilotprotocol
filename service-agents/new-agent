def main() -> None:
    parser = argparse.ArgumentParser(
        description="Scaffold a new Pilot Protocol service agent",
        formatter_class=argparse.RawDescriptionHelpFormatter,
        epilog=__doc__,
    )
    parser.add_argument("name", help="Agent name (e.g. 'weather-agent')")
    parser.add_argument("port", type=int, help="API port (e.g. 8400)")
    parser.add_argument("description", help="One-line description (quoted)")
    parser.add_argument("--endpoint", default="",
                        help="Endpoint name in endpoints.yaml (default: derived from name)")
    args = parser.parse_args()

    slug = slugify(args.name)
    endpoint = args.endpoint or slug

    dest = scaffold(args.name, args.port, args.description, endpoint)
    print_next_steps(args.name, slug, args.port, args.description, endpoint, dest)


if __name__ == "__main__":
    main()
