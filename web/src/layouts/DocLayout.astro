---
import BaseHead from '../components/BaseHead.astro';
import Topbar from '../components/Topbar.astro';
import DocSidebar from '../components/DocSidebar.astro';
import DocFooter from '../components/DocFooter.astro';
import PageNav from '../components/PageNav.astro';
import '../styles/global.css';
import '../styles/docs.css';

interface Props {
  title: string;
  description: string;
  activePage: string;
  canonicalPath?: string;
  prev?: { label: string; href: string };
  next?: { label: string; href: string };
}

const { title, description, activePage, canonicalPath, prev, next } = Astro.props;
const canonicalUrl = canonicalPath ? `https://pilotprotocol.network${canonicalPath}` : undefined;

const breadcrumbItems = [
  { name: "Home", url: "https://pilotprotocol.network/" },
  { name: "Docs", url: "https://pilotprotocol.network/docs/" },
];
if (activePage !== 'index') {
  breadcrumbItems.push({ name: title, url: canonicalUrl || "" });
}
---
<!DOCTYPE html>
<html lang="en">
<head>
  <BaseHead title={title} description={description} canonicalUrl={canonicalUrl} />
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "WebPage",
    "name": title,
    "description": description,
    "url": canonicalUrl,
    "isPartOf": { "@type": "WebSite", "name": "Pilot Protocol", "url": "https://pilotprotocol.network/" },
    "publisher": { "@type": "Organization", "name": "Vulture Labs" }
  })}></script>
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "BreadcrumbList",
    "itemListElement": breadcrumbItems.map((item, i) => ({
      "@type": "ListItem",
      "position": i + 1,
      "name": item.name,
      "item": item.url
    }))
  })}></script>
</head>
<body>
  <Topbar variant="docs" />
  <DocSidebar activePage={activePage} />
  <div class="content">
    {activePage !== 'index' && <nav class="breadcrumb" aria-label="Breadcrumb"><a href="/">Home</a> <span class="sep">/</span> <a href="/docs/">Docs</a> <span class="sep">/</span> <span>{title}</span></nav>}
    <slot />
    <PageNav prev={prev} next={next} />
  </div>
  <DocFooter />
</body>
</html>
