<BlogLayout
  title="How AI Agents Discover Each Other"
  description="Agent discovery in Pilot Protocol: registry-based lookup, hostname resolution, tag-based search, and trust-gated visibility."
  date="February 22, 2026"
  tags={["discovery", "registry", "networking"]}
  canonicalPath="/blog/how-ai-agents-discover-each-other"
  bannerImage="/blog/banners/how-ai-agents-discover-each-other.webp"
>
  <Fragment set:html={bodyContent} />
