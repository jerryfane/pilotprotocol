      appendLine(termAOutput, 'Daemon: running (pid 4821)', 'success');
      appendLine(termAOutput, '  Node ID:     ' + NODE_A, 'output');
      appendLine(termAOutput, '  Address:     ' + ADDR_A, 'output');
      appendLine(termAOutput, '  Hostname:    agent-a', 'output');
      appendLine(termAOutput, '  Uptime:      00:03:42', 'output');
      appendLine(termAOutput, '  Peers:       ' + (currentPhase >= 3 ? '1' : '0'), 'output');
      appendLine(termAOutput, '  Connections: ' + (currentPhase >= 3 ? '1' : '0'), 'output');
      appendLine(termAOutput, '', '');
      scrollDown(termABody);
      inputDisabled = false;
      return;
    }

    // ── Phase 2: Handshake (matches real output) ──
    if (cmd.indexOf('pilotctl handshake') === 0) {
      if (!requireDaemon()) { inputDisabled = false; return; }
      await sleep(200);
      // Real CLI prints hostname resolution to stderr
      appendLine(termAOutput, 'resolved "agent-b" \u2192 node ' + NODE_B, 'dim');
      await sleep(300);
      appendLine(termAOutput, 'handshake request sent to node ' + NODE_B, 'info');
      appendLine(termAOutput, '  next: node ' + NODE_B + ' must approve \u2014 or send a handshake back for auto-approval', 'output');
      appendLine(termAOutput, '  check: pilotctl trust', 'dim');
      appendLine(termAOutput, '', '');
      scrollDown(termABody);

      // Agent B receives pending handshake
      await sleep(800);
      appendLine(termBOutput, '', '');
      await typeInTermB('pilotctl pending');
      await sleep(200);
      appendLine(termBOutput, 'NODE ID     JUSTIFICATION                             RECEIVED', 'highlight');
      appendLine(termBOutput, '1           collaboration request                     2025-07-15 14:31:55', 'output');
      appendLine(termBOutput, '', '');
      scrollDown(termBBody);

      // Agent B approves via approve command (the real way)
      await sleep(400);
      await typeInTermB('pilotctl approve 1');
      await sleep(300);
      appendLine(termBOutput, 'trust established with node ' + NODE_A, 'success');
      appendLine(termBOutput, '  try: pilotctl ping ' + NODE_A, 'dim');
      appendLine(termBOutput, '', '');
      scrollDown(termBBody);

      // Agent A gets mutual trust notification
      await sleep(400);
      appendLine(termAOutput, '  \u2713 mutual trust established with node ' + NODE_B, 'success');
      appendLine(termAOutput, '', '');
      scrollDown(termABody);

      if (currentPhase === 2) setPhase(3);
      inputDisabled = false;
      return;
    }

    // ── Approve ──
    if (cmd.indexOf('pilotctl approve') === 0) {
      if (!requireDaemon()) { inputDisabled = false; return; }
      var approveArgs = cmd.split(/\s+/);
      var approveNodeId = approveArgs.length > 2 ? approveArgs[2] : '?';
