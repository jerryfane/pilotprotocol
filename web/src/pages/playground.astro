  // ── Tab completion ──
  function getCompletions(partial) {
    if (!partial) return [];
    var lower = partial.toLowerCase();
    return knownCommands.filter(function(c) { return c.toLowerCase().indexOf(lower) === 0 && c !== partial; });
  }

  function updateTabGhost() {
    var val = termAInput.value;
    var completions = getCompletions(val);
    if (completions.length > 0 && val.length > 0) {
      tabGhost.textContent = completions[0].slice(val.length);
    } else {
      tabGhost.textContent = '';
    }
  }

  function showCompletionMenu(completions) {
    if (completions.length === 0) {
      completionOverlay.classList.remove('show');
      return;
    }
    completionOverlay.innerHTML = '';
    completions.slice(0, 6).forEach(function(c, i) {
      var item = document.createElement('div');
      item.className = 'completion-item' + (i === completionIdx ? ' selected' : '');
      item.textContent = c;
      item.onclick = function() {
        termAInput.value = c;
        completionOverlay.classList.remove('show');
        tabGhost.textContent = '';
        termAInput.focus();
      };
      completionOverlay.appendChild(item);
    });
    var rect = termAInputLine.getBoundingClientRect();
    var termRect = document.getElementById('termA').getBoundingClientRect();
    completionOverlay.style.left = (rect.left - termRect.left) + 'px';
    completionOverlay.style.bottom = (termRect.bottom - rect.top + 4) + 'px';
    completionOverlay.classList.add('show');
  }

  // ── Input handling ──
  termAInput.addEventListener('keydown', function(e) {
    if (inputDisabled && e.key !== 'c') {
      e.preventDefault();
      return;
    }

    if (e.key === 'Tab') {
      e.preventDefault();
      var val = this.value;
      var completions = getCompletions(val);
      if (completions.length === 1) {
        this.value = completions[0];
        tabGhost.textContent = '';
        completionOverlay.classList.remove('show');
      } else if (completions.length > 1) {
        completionIdx = (completionIdx + 1) % completions.length;
        this.value = completions[completionIdx];
        showCompletionMenu(completions);
        tabGhost.textContent = '';
      }
      return;
    }

    if (e.key !== 'Tab') {
      completionIdx = -1;
      completionOverlay.classList.remove('show');
    }

    if (e.key === 'Enter') {
      e.preventDefault();
      processCommand(this.value);
      return;
    }

    if (e.key === 'ArrowUp') {
      e.preventDefault();
      if (cmdHistory.length > 0) {
        historyIdx = Math.max(0, historyIdx - 1);
        this.value = cmdHistory[historyIdx];
        tabGhost.textContent = '';
      }
      return;
    }

    if (e.key === 'ArrowDown') {
      e.preventDefault();
      if (historyIdx < cmdHistory.length - 1) {
        historyIdx++;
        this.value = cmdHistory[historyIdx];
      } else {
        historyIdx = cmdHistory.length;
        this.value = '';
      }
      tabGhost.textContent = '';
      return;
    }

    if (e.key === 'c' && e.ctrlKey) {
      e.preventDefault();
      appendCmd(termAOutput, termAPrompt.textContent, this.value + '^C');
      this.value = '';
      tabGhost.textContent = '';
      inputDisabled = false;
      scrollDown(termABody);
      return;
    }

    if (e.key === 'l' && e.ctrlKey) {
      e.preventDefault();
      termAOutput.innerHTML = '';
      return;
    }
  });

  termAInput.addEventListener('input', function() {
    updateTabGhost();
  });

  // ── Hint click ──
  hintCmd.addEventListener('click', function() {
    var cmd = hintCmd.textContent;
    if (cmd) {
      termAInput.value = cmd;
      tabGhost.textContent = '';
      termAInput.focus();
    }
  });

  // Click terminal to focus
  document.getElementById('termA').addEventListener('click', function() {
    termAInput.focus();
  });

  // Reset button
  document.getElementById('resetBtn').addEventListener('click', function() {
    termAOutput.innerHTML = '';
    termBOutput.innerHTML = '';
    termAInput.value = '';
    tabGhost.textContent = '';
    cmdHistory.length = 0;
    historyIdx = -1;
    inputDisabled = false;
    phase3Done.ping = false;
    phase3Done.send = false;
    phase3Done.bench = false;
    completionOverlay.classList.remove('show');
    document.getElementById('completeBanner').classList.remove('show');
    setPhase(0);
    termAPrompt.textContent = '~ $ ';

    appendLine(termAOutput, '  Welcome to the Pilot Protocol Playground', 'highlight');
    appendLine(termAOutput, '  Type commands below or click the hint to get started.', 'dim');
    appendLine(termAOutput, '', '');
    scrollDown(termABody);

    appendLine(termBOutput, '  agent-b is waiting for instructions...', 'dim');
    appendLine(termBOutput, '', '');
    scrollDown(termBBody);

    termAInput.focus();
  });

  // ── Confetti ──
  function launchConfetti() {
    var cel = document.getElementById('celebration');
    cel.classList.add('active');
    var colors = ['#22c55e', '#3b82f6', '#fbbf24', '#c084fc', '#ef4444', '#22d3ee', '#e5e5e5'];
    for (var i = 0; i < 80; i++) {
      var c = document.createElement('div');
      c.className = 'confetti';
      c.style.left = Math.random() * 100 + '%';
      c.style.backgroundColor = colors[Math.floor(Math.random() * colors.length)];
      c.style.width = (4 + Math.random() * 6) + 'px';
      c.style.height = (4 + Math.random() * 6) + 'px';
      c.style.animationDuration = (2 + Math.random() * 3) + 's';
      c.style.animationDelay = (Math.random() * 1.5) + 's';
      c.style.borderRadius = Math.random() > 0.5 ? '50%' : '2px';
      cel.appendChild(c);
    }
    setTimeout(function() {
      cel.classList.remove('active');
      cel.innerHTML = '';
    }, 5000);
  }

  // ── Init ──
  setPhase(0);
  appendLine(termAOutput, '  Welcome to the Pilot Protocol Playground', 'highlight');
  appendLine(termAOutput, '  Type commands below or click the hint to get started.', 'dim');
  appendLine(termAOutput, '', '');
  appendLine(termBOutput, '  agent-b is waiting for instructions...', 'dim');
  appendLine(termBOutput, '', '');

  termAInput.focus();
})();
</script>
</body>
</html>
