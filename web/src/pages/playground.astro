        appendLine(termAOutput, '1     7       ' + ADDR_B + '   7       ESTAB       16.0 KB   0 B       12ms     0       0      64.0 KB  64.0 KB', 'output');
        appendLine(termAOutput, '      tx: 4.2 KB (8 segs)  rx: 4.2 KB (8 segs)  retx: 0  fast-retx: 0  sack: 0/0  dup-ack: 0', 'dim');
      }
      appendLine(termAOutput, '', '');
      scrollDown(termABody);
      inputDisabled = false;
      return;
    }

    // ── Phase 3: Ping (exact format: resolves hostname, shows address) ──
    if (cmd.indexOf('pilotctl ping') === 0) {
      if (!requireDaemon()) { inputDisabled = false; return; }
      if (!requireTrust()) { inputDisabled = false; return; }
      // Real CLI: parseAddrOrHostname prints resolution to stderr
      appendLine(termAOutput, 'resolved "agent-b" \u2192 ' + ADDR_B, 'dim');
      await sleep(200);
      appendLine(termAOutput, 'PING ' + ADDR_B, 'info');
      scrollDown(termABody);
      var pings = [
        { seq: 0, bytes: 6, time: '14.231ms' },
        { seq: 1, bytes: 6, time: '12.847ms' },
        { seq: 2, bytes: 6, time: '13.102ms' },
        { seq: 3, bytes: 6, time: '11.956ms' },
      ];
      for (var pi = 0; pi < pings.length; pi++) {
        await sleep(800 + Math.random() * 400);
        appendLine(termAOutput, 'seq=' + pings[pi].seq + ' bytes=' + pings[pi].bytes + ' time=' + pings[pi].time, 'output');
        scrollDown(termABody);
      }
      appendLine(termAOutput, '', '');
      scrollDown(termABody);

      appendLine(termBOutput, '  \u2190 echo reply to ' + ADDR_A + ' (4 pings)', 'dim');
      scrollDown(termBBody);

      phase3Done.ping = true;
      checkPhase3Complete();
      inputDisabled = false;
      return;
    }

    // ── Phase 3: Send (exact syntax: pilotctl send <addr> <port> --data <msg>) ──
    if (cmd.indexOf('pilotctl send') === 0) {
      if (!requireDaemon()) { inputDisabled = false; return; }
      if (!requireTrust()) { inputDisabled = false; return; }
      var dataMatch = cmd.match(/--data\s+"([^"]+)"/);
      var data = dataMatch ? dataMatch[1] : 'hello';
      // Real CLI: hostname resolution
      appendLine(termAOutput, 'resolved "agent-b" \u2192 ' + ADDR_B, 'dim');
      await sleep(300);
      // Real CLI: send just prints the response, or "sent N bytes (no response)" to stderr
      // Echo port echoes back, so we simulate a response for data exchange port
      appendLine(termAOutput, data, 'output');
      appendLine(termAOutput, '', '');
      scrollDown(termABody);

      // Agent B shows received data
      await sleep(400);
      appendLine(termBOutput, '  \u2190 recv from ' + ADDR_A + ' port 1001: "' + data + '" (' + data.length + ' bytes)', 'dim');
      scrollDown(termBBody);

      phase3Done.send = true;
      checkPhase3Complete();
      inputDisabled = false;
      return;
    }

    // ── Phase 3: Bench (exact format from source) ──
    if (cmd.indexOf('pilotctl bench') === 0) {
      if (!requireDaemon()) { inputDisabled = false; return; }
      if (!requireTrust()) { inputDisabled = false; return; }
      // Real CLI: hostname resolution
      appendLine(termAOutput, 'resolved "agent-b" \u2192 ' + ADDR_B, 'dim');
      await sleep(200);
      appendLine(termAOutput, 'BENCH ' + ADDR_B + ' \u2014 sending 1.0 MB via echo port', 'info');
      scrollDown(termABody);
      await sleep(1200);

      appendLine(termAOutput, '  Sent:     1.0 MB in 82ms (12.2 MB/s)', 'output');
      await sleep(600);
      appendLine(termAOutput, '  Echoed:   1.0 MB in 168ms (5.9 MB/s round-trip)', 'success');
      appendLine(termAOutput, '', '');
      scrollDown(termABody);

      appendLine(termBOutput, '  \u2190 echo: 1.0 MB round-trip from ' + ADDR_A, 'dim');
      scrollDown(termBBody);

      phase3Done.bench = true;
      checkPhase3Complete();
      inputDisabled = false;
      return;
    }

    // ── Unknown command ──
    if (cmd.indexOf('pilotctl') === 0) {
      var sub = cmd.split(/\s+/).slice(1).join(' ');
      appendLine(termAOutput, 'error: unknown command "' + sub + '"', 'error');
      appendLine(termAOutput, '  run "pilotctl context" for available commands', 'dim');
    } else if (currentPhase < 1) {
      appendLine(termAOutput, '-bash: ' + cmd.split(/\s+/)[0] + ': command not found', 'error');
    } else {
      appendLine(termAOutput, '-bash: ' + cmd.split(/\s+/)[0] + ': command not found', 'error');
    }
    appendLine(termAOutput, '', '');
    scrollDown(termABody);
    inputDisabled = false;
  }

  function checkPhase3Complete() {
    var done = [phase3Done.ping, phase3Done.send, phase3Done.bench].filter(Boolean).length;
    if (done >= 2 && currentPhase === 3) {
      setPhase(4);
      showComplete();
    }
    if (currentPhase === 3) {
      if (!phase3Done.ping) {
        hintCmd.textContent = 'pilotctl ping agent-b';
        hintText.textContent = 'Test the connection \u2014 try ping:';
      } else if (!phase3Done.send) {
        hintCmd.textContent = 'pilotctl send agent-b 1001 --data "hello from agent-a"';
        hintText.textContent = 'Send data to agent-b:';
      } else if (!phase3Done.bench) {
        hintCmd.textContent = 'pilotctl bench agent-b';
        hintText.textContent = 'Benchmark throughput:';
      }
    }
  }

