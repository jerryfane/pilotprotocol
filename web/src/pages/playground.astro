      if (currentPhase === 1) setPhase(2);
      inputDisabled = false;
      return;
    }

    // ── Daemon status (real command) ──
    if (cmd === 'pilotctl daemon status') {
      if (currentPhase < 2) {
        appendLine(termAOutput, 'Daemon: stopped', 'output');
        appendLine(termAOutput, '  start with: pilotctl daemon start', 'dim');
