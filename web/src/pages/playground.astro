      return;
    }

    // ── Info (the real status command) ──
    if (cmd === 'pilotctl info') {
      if (!requireDaemon()) { inputDisabled = false; return; }
      await sleep(250);
      var nPeers = currentPhase >= 3 ? 1 : 0;
      var nConns = currentPhase >= 3 ? 1 : 0;
      appendLine(termAOutput, 'Pilot Protocol Daemon', 'highlight');
      appendLine(termAOutput, '  Node ID:     ' + NODE_A, 'output');
      appendLine(termAOutput, '  Address:     ' + ADDR_A, 'output');
      appendLine(termAOutput, '  Hostname:    agent-a', 'output');
      appendLine(termAOutput, '  Uptime:      00:03:42', 'output');
      appendLine(termAOutput, '  Connections: ' + nConns, 'output');
      appendLine(termAOutput, '  Ports:       3', 'output');
      appendLine(termAOutput, '  Peers:       ' + nPeers, 'output');
      appendLine(termAOutput, '  Encryption:  enabled (X25519 + AES-256-GCM), ' + nPeers + '/' + nPeers + ' peers encrypted, ' + nPeers + ' authenticated', 'output');
      appendLine(termAOutput, '  Identity:    persistent (Ed25519 a4f2c8d19e3b7a01...)', 'output');
      appendLine(termAOutput, '  Traffic:     ' + (nConns ? '4.2 KB' : '0 B') + ' sent / ' + (nConns ? '4.2 KB' : '0 B') + ' recv', 'output');
      appendLine(termAOutput, '  Packets:     ' + (nConns ? '12' : '0') + ' sent / ' + (nConns ? '12' : '0') + ' recv', 'output');
      if (nConns > 0) {
        appendLine(termAOutput, '');
        appendLine(termAOutput, 'Active connections: ' + nConns, 'output');
        appendLine(termAOutput, '  ID    LOCAL   REMOTE ADDR             RPORT   STATE       CWND      FLIGHT    SRTT', 'output');
        appendLine(termAOutput, '  1     7       ' + ADDR_B + '   7       ESTAB       16.0 KB   0 B       12ms', 'output');
      }
      appendLine(termAOutput, '', '');
      scrollDown(termABody);
      inputDisabled = false;
      return;
    }

    // ── Trust list (exact format from source) ──
    if (cmd === 'pilotctl trust') {
      if (!requireDaemon()) { inputDisabled = false; return; }
      await sleep(200);
      if (currentPhase < 3) {
        appendLine(termAOutput, 'no trusted peers', 'output');
        appendLine(termAOutput, '  establish trust: pilotctl handshake <node_id|hostname> "reason"', 'dim');
      } else {
        appendLine(termAOutput, 'NODE ID     MUTUAL      NETWORK     APPROVED AT', 'highlight');
        appendLine(termAOutput, '2           yes         0           2025-07-15 14:32:08', 'output');
      }
      appendLine(termAOutput, '', '');
      scrollDown(termABody);
      inputDisabled = false;
      return;
    }

    // ── Pending (exact format from source) ──
    if (cmd === 'pilotctl pending') {
      if (!requireDaemon()) { inputDisabled = false; return; }
      await sleep(200);
      appendLine(termAOutput, 'no pending handshake requests', 'output');
      appendLine(termAOutput, '  requests appear here when another node sends: pilotctl handshake <your-node-id>', 'dim');
      appendLine(termAOutput, '', '');
      scrollDown(termABody);
      inputDisabled = false;
      return;
    }

    // ── Peers (exact format from source) ──
    if (cmd.indexOf('pilotctl peers') === 0) {
      if (!requireDaemon()) { inputDisabled = false; return; }
      await sleep(200);
      if (currentPhase < 3) {
        appendLine(termAOutput, 'no peers connected', 'output');
        appendLine(termAOutput, '  peers appear when you communicate with other nodes', 'dim');
      } else {
        appendLine(termAOutput, 'NODE ID     ENDPOINT                        ENCRYPTED             AUTH', 'highlight');
        appendLine(termAOutput, '2           192.168.1.42:4000               yes (AES-256-GCM)     yes (Ed25519)', 'output');
      }
      appendLine(termAOutput, '', '');
      scrollDown(termABody);
      inputDisabled = false;
      return;
    }

    // ── Connections (exact format from source) ──
    if (cmd === 'pilotctl connections') {
      if (!requireDaemon()) { inputDisabled = false; return; }
      await sleep(200);
      if (currentPhase < 3) {
        appendLine(termAOutput, 'no active connections', 'output');
