---
import BaseHead from '../../components/BaseHead.astro';
import IslandNavbar from '../../components/IslandNavbar.astro';
import BlogFooter from '../../components/BlogFooter.astro';
import '../../styles/global.css';

const title = "Skill Zoo — 80+ Agent Skills for Pilot Protocol";
const description = "Browse the complete catalog of Pilot Protocol agent skills. Communication, file transfer, trust, task routing, swarm coordination, and more — all installable with one command.";
const canonicalUrl = "https://pilotprotocol.network/for/skills";

// Fetch skills.json at build time
let catalog = { categories: [], total: 0 };
try {
  const res = await fetch("https://raw.githubusercontent.com/TeoSlayer/pilot-skills/main/skills.json");
  if (res.ok) catalog = await res.json();
} catch {}
---
<!DOCTYPE html>
<html lang="en">
<head>
  <BaseHead title={title} description={description} canonicalUrl={canonicalUrl} />
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "CollectionPage",
    "name": title,
    "description": description,
    "url": canonicalUrl,
    "publisher": {"@type": "Organization", "name": "Vulture Labs", "url": "https://vulturelabs.com"},
  })}></script>
<style is:inline>
*{margin:0;padding:0;box-sizing:border-box}
:root{--bg:#0a0a0a;--fg:#e5e5e5;--muted:#737373;--accent:#22c55e;--accent2:#3b82f6;--surface:rgba(255,255,255,0.05);--border:rgba(255,255,255,0.08);--glass-bg:rgba(255,255,255,0.06);--glass-border:rgba(255,255,255,0.12);--glass-shadow:0 8px 32px rgba(0,0,0,0.4),inset 0 1px 0 rgba(255,255,255,0.06)}
html,body{overflow-x:hidden}
body{font-family:-apple-system,BlinkMacSystemFont,'Segoe UI',Roboto,sans-serif;background:var(--bg);color:var(--fg);line-height:1.6;-webkit-font-smoothing:antialiased}
a{color:var(--accent);text-decoration:none}
a:hover{text-decoration:underline}
code{font-family:'SF Mono',Menlo,Consolas,monospace}
.container{max-width:960px;margin:0 auto;padding:0 24px;position:relative;z-index:1}

/* Hero */
.hero-frame{border:1px dashed rgba(255,255,255,0.08);border-radius:16px;padding:36px 32px;margin:100px 0 48px;position:relative;text-align:center}
.hero-frame::before{content:'';position:absolute;top:50%;left:50%;transform:translate(-50%,-50%);width:600px;height:400px;background:radial-gradient(ellipse,rgba(34,197,94,0.04) 0%,transparent 70%);pointer-events:none;z-index:0}
.hero-frame h1{font-size:2.4rem;font-weight:800;letter-spacing:-0.03em;margin-bottom:12px;line-height:1.1;position:relative;z-index:1}
.hero-frame .tagline{font-size:1.05rem;color:var(--muted);margin-bottom:24px;line-height:1.65;max-width:560px;margin-left:auto;margin-right:auto;position:relative;z-index:1}
.hero-stats{display:flex;justify-content:center;gap:32px;position:relative;z-index:1}
.hero-stat{text-align:center}
.hero-stat .num{font-size:2rem;font-weight:800;color:var(--accent);font-family:'SF Mono',Menlo,Consolas,monospace}
.hero-stat .label{font-size:0.78rem;color:var(--muted);text-transform:uppercase;letter-spacing:0.06em}

/* Search & Filter */
.filter-bar{display:flex;gap:12px;margin-bottom:32px;flex-wrap:wrap;align-items:center}
.search-box{flex:1;min-width:200px;padding:10px 16px;border-radius:8px;border:1px solid var(--border);background:var(--glass-bg);color:var(--fg);font-size:0.88rem;font-family:inherit;outline:none;backdrop-filter:blur(20px);-webkit-backdrop-filter:blur(20px);transition:border-color 0.2s}
.search-box:focus{border-color:rgba(34,197,94,0.4)}
.search-box::placeholder{color:var(--muted)}
.filter-pills{display:flex;gap:6px;flex-wrap:wrap}
.pill{padding:6px 14px;border-radius:20px;border:1px solid var(--border);background:transparent;color:var(--muted);font-size:0.78rem;cursor:pointer;font-family:inherit;transition:all 0.15s;white-space:nowrap}
.pill:hover{color:var(--fg);border-color:rgba(255,255,255,0.2)}
.pill.active{color:var(--fg);background:rgba(34,197,94,0.12);border-color:rgba(34,197,94,0.4)}
.result-count{font-size:0.8rem;color:var(--muted);margin-bottom:20px}

/* Category sections */
.cat-section{margin-bottom:40px}
.cat-header{display:flex;align-items:center;gap:12px;margin-bottom:16px}
.cat-header h2{font-size:1.3rem;font-weight:700;letter-spacing:-0.02em}
.cat-count{font-size:0.75rem;color:var(--muted);background:var(--surface);padding:2px 10px;border-radius:12px}
.cat-grid{display:grid;grid-template-columns:repeat(auto-fill,minmax(280px,1fr));gap:14px}

/* Skill cards */
.skill-card{background:var(--glass-bg);border:1px solid var(--glass-border);border-radius:12px;padding:20px;backdrop-filter:blur(20px);-webkit-backdrop-filter:blur(20px);box-shadow:var(--glass-shadow);transition:border-color 0.2s,transform 0.2s}
.skill-card:hover{border-color:rgba(34,197,94,0.3);transform:translateY(-2px)}
.skill-card.hidden{display:none}
.skill-name{font-size:0.92rem;font-weight:600;margin-bottom:6px;display:flex;align-items:center;gap:8px}
.skill-name a{color:var(--fg)}
.skill-name a:hover{color:var(--accent);text-decoration:none}
.skill-desc{font-size:0.82rem;color:var(--muted);line-height:1.5;margin-bottom:10px;display:-webkit-box;-webkit-line-clamp:2;-webkit-box-orient:vertical;overflow:hidden}
.skill-tags{display:flex;flex-wrap:wrap;gap:4px;margin-bottom:12px}
.skill-tag{font-size:0.68rem;color:rgba(255,255,255,0.5);background:rgba(255,255,255,0.04);padding:2px 8px;border-radius:10px}
.skill-actions{display:flex;gap:8px;align-items:center}
.install-cmd{font-size:0.75rem;color:var(--accent);background:rgba(34,197,94,0.08);padding:4px 10px;border-radius:6px;font-family:'SF Mono',Menlo,Consolas,monospace;flex:1;overflow:hidden;text-overflow:ellipsis;white-space:nowrap}
.skill-links{display:flex;gap:6px;flex-shrink:0}
.skill-link{font-size:0.72rem;color:var(--muted);padding:4px 8px;border-radius:4px;border:1px solid var(--border);transition:all 0.15s;white-space:nowrap}
.skill-link:hover{color:var(--fg);border-color:rgba(255,255,255,0.2);text-decoration:none}

/* Install section */
.install-section{text-align:center;padding:48px 24px;margin:20px 0 40px;background:var(--glass-bg);border:1px solid var(--glass-border);border-radius:14px;backdrop-filter:blur(20px);-webkit-backdrop-filter:blur(20px);box-shadow:var(--glass-shadow)}
.install-section h3{font-size:1.3rem;font-weight:700;margin-bottom:8px}
.install-section p{color:var(--muted);font-size:0.9rem;margin-bottom:20px}
.install-section code{display:inline-block;background:rgba(34,197,94,0.08);color:var(--accent);padding:8px 20px;border-radius:8px;font-size:0.88rem;margin-bottom:8px}
.install-section .install-alt{font-size:0.82rem;color:var(--muted);margin-top:12px}
.install-section .install-alt a{color:var(--accent)}

/* Responsive */
@media(max-width:768px){
  .container{padding:0 16px}
  .hero-frame{padding:24px 16px;margin:68px 0 32px}
  .hero-frame h1{font-size:1.8rem}
  .hero-stats{gap:20px}
  .hero-stat .num{font-size:1.6rem}
  .filter-bar{flex-direction:column}
  .search-box{min-width:0}
  .cat-grid{grid-template-columns:1fr}
}
@media(max-width:480px){
  .hero-frame h1{font-size:1.5rem}
  .hero-frame{padding:20px 12px;margin:60px 0 24px}
  .hero-stats{flex-direction:column;gap:12px}
}
</style>
</head>
<body>

<IslandNavbar active="solutions" />

<div class="container">

<!-- Hero -->
<div class="hero-frame">
  <h1>Skill Zoo</h1>
  <p class="tagline">The complete catalog of Pilot Protocol agent skills. Every skill wraps <code>pilotctl</code> to give agents a focused capability — installable with one command.</p>
  <div class="hero-stats">
    <div class="hero-stat">
      <div class="num">{catalog.total}</div>
      <div class="label">Skills</div>
    </div>
    <div class="hero-stat">
      <div class="num">{catalog.categories.length}</div>
      <div class="label">Categories</div>
    </div>
    <div class="hero-stat">
      <div class="num">1</div>
      <div class="label">Command Install</div>
    </div>
  </div>
</div>

<!-- Search & Filter -->
<div class="filter-bar">
  <input class="search-box" type="text" id="skill-search" placeholder="Search skills..." autocomplete="off">
  <div class="filter-pills" id="filter-pills">
    <button class="pill active" data-cat="all">All</button>
    {catalog.categories.map(cat => (
      <button class="pill" data-cat={cat.slug}>{cat.name}</button>
    ))}
  </div>
</div>
<div class="result-count" id="result-count">{catalog.total} skills</div>

<!-- Category sections -->
{catalog.categories.map(cat => (
  <div class="cat-section" data-category={cat.slug}>
    <div class="cat-header">
      <h2>{cat.name}</h2>
      <span class="cat-count">{cat.skills.length}</span>
    </div>
    <div class="cat-grid">
      {cat.skills.map(skill => (
        <div class="skill-card" data-tags={skill.tags.join(' ')} data-name={skill.name} data-desc={skill.description}>
          <div class="skill-name">
            <a href={skill.source} target="_blank" rel="noopener">{skill.name}</a>
          </div>
          <div class="skill-desc">{skill.description}</div>
          <div class="skill-tags">
            {skill.tags.map(tag => (
              <span class="skill-tag">{tag}</span>
            ))}
          </div>
          <div class="skill-actions">
            <code class="install-cmd">{skill.install}</code>
            <div class="skill-links">
              <a class="skill-link" href={skill.clawhub_url} target="_blank" rel="noopener">ClawHub</a>
              <a class="skill-link" href={skill.source} target="_blank" rel="noopener">Source</a>
            </div>
          </div>
        </div>
      ))}
    </div>
  </div>
))}

<!-- Setups CTA -->
<div class="install-section" style="margin-bottom:24px">
  <h3>See these skills in action</h3>
  <p>Explore curated multi-agent deployment recipes that combine skills into real infrastructure patterns.</p>
  <div style="margin-top:4px">
    <a href="/for/setups" style="display:inline-block;padding:8px 20px;border-radius:8px;background:var(--accent);color:#000;font-weight:600;font-size:0.88rem;transition:opacity 0.2s">Browse Setups</a>
  </div>
</div>

<!-- Install CTA -->
<div class="install-section">
  <h3>Install any skill in one command</h3>
  <p>Every skill is available on ClawHub. Install the core skill to get started.</p>
  <code>clawhub install pilotprotocol</code>
  <div class="install-alt">
    Or install the daemon directly: <code style="padding:4px 10px;font-size:0.82rem">curl -fsSL https://pilotprotocol.network/install.sh | sh</code>
  </div>
  <div class="install-alt" style="margin-top:8px">
    <a href="https://clawhub.ai/teoslayer/pilotprotocol" target="_blank" rel="noopener">View on ClawHub</a> &middot;
    <a href="https://github.com/TeoSlayer/pilot-skills" target="_blank" rel="noopener">GitHub</a> &middot;
    <a href="/docs/getting-started">Getting Started</a>
  </div>
</div>

</div>

<BlogFooter />

<script is:inline>
(function(){
  var search = document.getElementById('skill-search');
  var pills = document.querySelectorAll('.pill');
  var sections = document.querySelectorAll('.cat-section');
  var cards = document.querySelectorAll('.skill-card');
  var counter = document.getElementById('result-count');
  var activeCat = 'all';

  function filter(){
    var q = search.value.toLowerCase().trim();
    var visible = 0;

    sections.forEach(function(sec){
      var cat = sec.dataset.category;
      var catVisible = 0;
      sec.querySelectorAll('.skill-card').forEach(function(card){
        var matchCat = activeCat === 'all' || cat === activeCat;
        var matchText = !q ||
          card.dataset.name.toLowerCase().indexOf(q) !== -1 ||
          card.dataset.desc.toLowerCase().indexOf(q) !== -1 ||
          card.dataset.tags.toLowerCase().indexOf(q) !== -1;
        if(matchCat && matchText){
          card.classList.remove('hidden');
          catVisible++;
          visible++;
        } else {
          card.classList.add('hidden');
        }
      });
      sec.style.display = catVisible > 0 ? '' : 'none';
    });

    counter.textContent = visible + ' skill' + (visible !== 1 ? 's' : '');
  }

  search.addEventListener('input', filter);

  pills.forEach(function(pill){
    pill.addEventListener('click', function(){
      pills.forEach(function(p){ p.classList.remove('active') });
      pill.classList.add('active');
      activeCat = pill.dataset.cat;
      filter();
    });
  });
})();
</script>
</body>
</html>
