<script is:inline>
function copyCmd(id,btn){
  navigator.clipboard.writeText(document.getElementById(id).textContent.trim());
  btn.textContent='Copied';
  setTimeout(function(){btn.textContent='Copy'},1500);
}

// Sequential step reveal
function triggerSteps(panel){
  panel.classList.add('in-view');
  var steps = panel.querySelectorAll('.uc-step');
  steps.forEach(function(s){s.style.animation='none';s.style.opacity='0';s.classList.remove('revealed')});
  var i = 0;
  function next(){
    if(i >= steps.length) return;
    var step = steps[i]; i++;
    step.classList.add('revealed');
    step.style.animation='';
    var isWinLine = step.closest('.uc-win-body');
    var dur = isWinLine ? 250 : 400;
    setTimeout(next, dur);
  }
  setTimeout(next, 150);
}

// Use Cases nav switching
document.querySelectorAll('.uc-btn').forEach(function(btn){
  btn.addEventListener('click',function(){
    document.querySelectorAll('.uc-btn').forEach(function(b){b.classList.remove('active')});
    document.querySelectorAll('.uc-panel').forEach(function(p){p.classList.remove('active');p.classList.remove('in-view')});
    btn.classList.add('active');
    var panel = document.getElementById('uc-'+btn.dataset.uc);
    panel.classList.add('active');
    triggerSteps(panel);
  });
});

// FAQ accordion
document.querySelectorAll('.faq-q').forEach(function(btn){
  btn.addEventListener('click',function(){
    btn.parentElement.classList.toggle('open');
  });
});

// Scroll-triggered animation
var observer = new IntersectionObserver(function(entries){
  entries.forEach(function(entry){
    if(entry.isIntersecting){
      var panel = entry.target.querySelector('.uc-panel.active');
      if(panel && !panel.classList.contains('in-view')){
        triggerSteps(panel);
      }
    }
  });
},{threshold:0.2});
document.querySelectorAll('.uc-layout').forEach(function(el){observer.observe(el)});
</script>
