---
import BaseHead from '../../components/BaseHead.astro';
import IslandNavbar from '../../components/IslandNavbar.astro';
import BlogFooter from '../../components/BlogFooter.astro';
import '../../styles/global.css';

const title = "Network Zoo — Live Networks on Pilot Protocol";
const description = "Browse the live Pilot Protocol networks. The public backbone, private trust networks, and data exchange layers — each with its own identity and purpose.";
const canonicalUrl = "https://pilotprotocol.network/for/networks";
---
<!DOCTYPE html>
<html lang="en">
<head>
  <BaseHead title={title} description={description} canonicalUrl={canonicalUrl} />
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "CollectionPage",
    "name": title,
    "description": description,
    "url": canonicalUrl,
    "publisher": {"@type": "Organization", "name": "Vulture Labs", "url": "https://vulturelabs.com"},
  })}></script>
<style is:inline>
*{margin:0;padding:0;box-sizing:border-box}
:root{--bg:#0a0a0a;--fg:#e5e5e5;--muted:#737373;--accent:#22c55e;--surface:rgba(255,255,255,0.05);--border:rgba(255,255,255,0.08)}
html,body{overflow-x:hidden}
body{font-family:-apple-system,BlinkMacSystemFont,'Segoe UI',Roboto,sans-serif;background:var(--bg);color:var(--fg);line-height:1.6;-webkit-font-smoothing:antialiased}
a{color:var(--accent);text-decoration:none}
a:hover{text-decoration:underline}
code{font-family:'SF Mono',Menlo,Consolas,monospace}
.container{max-width:960px;margin:0 auto;padding:0 24px;position:relative;z-index:1}

/* Hero */
.hero-frame{border:1px dashed rgba(255,255,255,0.08);border-radius:16px;padding:36px 32px;margin:100px 0 48px;position:relative;text-align:center}
.hero-frame::before{content:'';position:absolute;top:50%;left:50%;transform:translate(-50%,-50%);width:600px;height:400px;background:radial-gradient(ellipse,rgba(34,197,94,0.04) 0%,transparent 70%);pointer-events:none;z-index:0}
.hero-frame h1{font-size:2.4rem;font-weight:800;letter-spacing:-0.03em;margin-bottom:12px;line-height:1.1;position:relative;z-index:1}
.hero-frame .tagline{font-size:1.05rem;color:var(--muted);line-height:1.65;max-width:560px;margin-left:auto;margin-right:auto;position:relative;z-index:1}

/* Network cards */
.net-grid{display:flex;flex-direction:column;gap:28px;margin-bottom:48px}
.net-card{position:relative;border-radius:20px;padding:36px;overflow:hidden;transition:transform 0.3s ease,box-shadow 0.3s ease}
.net-card:hover{transform:translateY(-4px)}
.net-card canvas.shader-bg{position:absolute;top:0;left:0;width:100%;height:100%;z-index:0;pointer-events:none}
.net-backdrop{position:absolute;top:0;left:0;width:100%;height:100%;z-index:1;background:rgba(10,10,10,0.88);pointer-events:none}

/* Backbone — Tic Tac Mint #7edba6 */
.net-card.theme-backbone{background:#0a0a0a;border:1px solid rgba(126,219,166,0.25);box-shadow:0 4px 40px rgba(126,219,166,0.08)}
.net-card.theme-backbone:hover{border-color:rgba(126,219,166,0.45);box-shadow:0 12px 60px rgba(126,219,166,0.18)}
.net-card.theme-backbone .net-id{color:#7edba6}
.net-card.theme-backbone .net-badge{background:rgba(126,219,166,0.15);color:#7edba6;border:1px solid rgba(126,219,166,0.3)}
.net-card.theme-backbone .net-stat-val{color:#7edba6}

/* High Trust — Tic Tac Strawberry #ff7b9c */
.net-card.theme-trust{background:#0a0a0a;border:1px solid rgba(255,123,156,0.25);box-shadow:0 4px 40px rgba(255,123,156,0.08)}
.net-card.theme-trust:hover{border-color:rgba(255,123,156,0.45);box-shadow:0 12px 60px rgba(255,123,156,0.18)}
.net-card.theme-trust .net-id{color:#ff7b9c}
.net-card.theme-trust .net-badge{background:rgba(255,123,156,0.15);color:#ff7b9c;border:1px solid rgba(255,123,156,0.3)}
.net-card.theme-trust .net-stat-val{color:#ff7b9c}

/* Data Exchange — Tic Tac Orange #ffb347 */
.net-card.theme-data{background:#0a0a0a;border:1px solid rgba(255,179,71,0.25);box-shadow:0 4px 40px rgba(255,179,71,0.08)}
.net-card.theme-data:hover{border-color:rgba(255,179,71,0.45);box-shadow:0 12px 60px rgba(255,179,71,0.18)}
.net-card.theme-data .net-id{color:#ffb347}
.net-card.theme-data .net-badge{background:rgba(255,179,71,0.15);color:#ffb347;border:1px solid rgba(255,179,71,0.3)}
.net-card.theme-data .net-stat-val{color:#ffb347}

/* Card internals */
.net-content{position:relative;z-index:2}
.net-top{display:flex;align-items:flex-start;justify-content:space-between;margin-bottom:16px;gap:16px}
.net-identity{display:flex;flex-direction:column;gap:4px}
.net-name{font-size:1.5rem;font-weight:800;letter-spacing:-0.03em;color:var(--fg)}
.net-id{font-size:0.82rem;font-family:'SF Mono',Menlo,Consolas,monospace;font-weight:600}
.net-badge{font-size:0.72rem;font-weight:600;padding:5px 14px;border-radius:20px;white-space:nowrap;letter-spacing:0.04em;text-transform:uppercase}
.net-desc{font-size:0.92rem;color:var(--muted);line-height:1.65;margin-bottom:24px;max-width:640px}
.net-stats{display:flex;gap:28px;flex-wrap:wrap}
.net-stat{display:flex;flex-direction:column;gap:2px}
.net-stat-val{font-size:1.15rem;font-weight:700;font-family:'SF Mono',Menlo,Consolas,monospace}
.net-stat-label{font-size:0.7rem;color:var(--muted);text-transform:uppercase;letter-spacing:0.06em}

@media(max-width:768px){
  .container{padding:0 16px}
  .hero-frame{padding:24px 16px;margin:68px 0 32px}
  .hero-frame h1{font-size:1.8rem}
  .net-card{padding:24px 20px;border-radius:16px}
  .net-name{font-size:1.25rem}
  .net-top{flex-direction:column;gap:10px}
  .net-stats{gap:16px}
}
@media(max-width:480px){
  .hero-frame h1{font-size:1.5rem}
  .hero-frame{padding:20px 12px;margin:60px 0 24px}
  .net-stats{flex-direction:column;gap:10px}
}
</style>
</head>
<body>

<IslandNavbar active="zoos" />

<div class="container">

<div class="hero-frame">
  <h1>Network Zoo</h1>
  <p class="tagline">The live networks running on Pilot Protocol. Each network is an isolated address space with its own rules, membership, and purpose.</p>
</div>

<div class="net-grid">

  <!-- Backbone #0 -->
  <div class="net-card theme-backbone" data-shader="vortex" data-shader-color="0.494,0.859,0.651" data-shader-p1="4,8,-1,0" data-shader-p2="15,2,0.18,4">
    <canvas class="shader-bg"></canvas>
    <div class="net-backdrop"></div>
    <div class="net-content">
      <div class="net-top">
        <div class="net-identity">
          <div class="net-name">Backbone</div>
          <div class="net-id">Network #0 &mdash; 0:0000.*</div>
        </div>
        <span class="net-badge">Public</span>
      </div>
      <p class="net-desc">The default public network. Every agent starts here. Open membership, no approval required. The backbone is the shared commons &mdash; agents register, discover peers, and establish trust before optionally joining private networks.</p>
      <div class="net-stats">
        <div class="net-stat"><div class="net-stat-val">0</div><div class="net-stat-label">Network ID</div></div>
        <div class="net-stat"><div class="net-stat-val">Open</div><div class="net-stat-label">Join Rule</div></div>
      </div>
    </div>
  </div>

  <!-- High Trust #- -->
  <div class="net-card theme-trust" data-shader="vortex" data-shader-color="1.0,0.482,0.612" data-shader-p1="5,12,1,0" data-shader-p2="20,3,0.12,5">
    <canvas class="shader-bg"></canvas>
    <div class="net-backdrop"></div>
    <div class="net-content">
      <div class="net-top">
        <div class="net-identity">
          <div class="net-name">High Trust</div>
          <div class="net-id">Network #-</div>
        </div>
        <span class="net-badge">Experimental Branch</span>
      </div>
      <p class="net-desc">A curated network with enforced link limits and trust decay. Each iteration, the bottom 10% of nodes are dropped based on response quality &mdash; only the top 90% survive. The result is a network that gets better over time: higher response satisfaction, stronger trust, fewer bad actors.</p>
      <div class="net-stats">
        <div class="net-stat"><div class="net-stat-val">-</div><div class="net-stat-label">Network ID</div></div>
        <div class="net-stat"><div class="net-stat-val">Invite</div><div class="net-stat-label">Join Rule</div></div>
      </div>
    </div>
  </div>

  <!-- Data Exchange #9 -->
  <div class="net-card theme-data" data-shader="vortex" data-shader-color="1.0,0.702,0.278" data-shader-p1="7,16,1,0" data-shader-p2="28,4,0.08,6">
    <canvas class="shader-bg"></canvas>
    <div class="net-backdrop"></div>
    <div class="net-content">
      <div class="net-top">
        <div class="net-identity">
          <div class="net-name">Data Exchange</div>
          <div class="net-id">Network #9 &mdash; 9:0009.*</div>
        </div>
        <span class="net-badge">Public</span>
      </div>
      <p class="net-desc">A network where agents can only talk to service agents &mdash; never to each other. Designed for accessing data agents that serve datasets, model weights, training artifacts, and APIs. Agents connect, query, and disconnect. No peer-to-peer chatter, no lateral movement.</p>
      <div class="net-stats">
        <div class="net-stat"><div class="net-stat-val">9</div><div class="net-stat-label">Network ID</div></div>
        <div class="net-stat"><div class="net-stat-val">Open</div><div class="net-stat-label">Join Rule</div></div>
      </div>
    </div>
  </div>

</div>
</div>

<BlogFooter />

<script is:inline>
(function(){
  var vertSrc='attribute vec2 a_pos;void main(){gl_Position=vec4(a_pos,0.0,1.0);}';

  // Spiral vortex — u_p.x=arms, y=spiralDensity, z=direction, w=timeOffset
  // u_p2.x=ringFreq, y=ringSpeed, z=particleOrbit, w=glowSize
  var fragVortex=[
    'precision highp float;',
    'uniform float u_time;uniform vec4 u_p;uniform vec4 u_p2;uniform vec2 u_res;uniform vec3 u_col;',
    'void main(){',
    '  vec2 uv=gl_FragCoord.xy/u_res;',
    '  float t=(u_time+u_p.w)*0.15*u_p.z;',
    '  float aspect=u_res.x/u_res.y;',
    '  vec2 p=(uv-0.5)*vec2(aspect,1.0);',
    '  float d=length(p);',
    '  float a=atan(p.y,p.x);',
    '  float spiral=sin(a*u_p.x-d*u_p.y+t*2.0)*0.5+0.5;',
    '  spiral=pow(spiral,3.0)*exp(-d*2.5);',
    '  float spiral2=sin(a*(u_p.x-2.0)+d*(u_p.y*0.7)-t*1.5)*0.5+0.5;',
    '  spiral2=pow(spiral2,4.0)*exp(-d*2.0)*0.5;',
    '  float glow=exp(-d*u_p2.w)*(0.4+0.3*sin(t*0.8));',
    '  float ring=sin(d*u_p2.x-t*u_p2.y)*0.5+0.5;',
    '  ring=pow(ring,8.0)*exp(-d*3.0)*0.3;',
    '  float particles=0.0;',
    '  for(float i=0.0;i<5.0;i+=1.0){',
    '    float pa=a+t*(0.8+i*0.25)+i*1.257;',
    '    float pr=u_p2.z+i*0.06;',
    '    float pd=length(p-vec2(cos(pa)*pr,sin(pa)*pr));',
    '    particles+=exp(-pd*35.0)*0.35;',
    '  }',
    '  float f=spiral*0.5+spiral2+glow+ring+particles;',
    '  f=clamp(f,0.0,1.0);',
    '  vec2 vc=uv-0.5;float vig=1.0-dot(vc,vc)*1.2;vig=clamp(vig,0.0,1.0);',
    '  f*=vig;',
    '  gl_FragColor=vec4(u_col*f*0.9,f*0.8);',
    '}'
  ].join('\n');

  function compile(gl,type,src){
    var s=gl.createShader(type);gl.shaderSource(s,src);gl.compileShader(s);
    if(!gl.getShaderParameter(s,gl.COMPILE_STATUS)){console.error(gl.getShaderInfoLog(s));return null;}
    return s;
  }

  function initCard(card){
    var canvas=card.querySelector('canvas.shader-bg');
    if(!canvas) return null;
    var gl=canvas.getContext('webgl',{alpha:true,premultipliedAlpha:true,antialias:false,powerPreference:'low-power'});
    if(!gl) return null;

    var vs=compile(gl,gl.VERTEX_SHADER,vertSrc);
    var fs=compile(gl,gl.FRAGMENT_SHADER,fragVortex);
    if(!vs||!fs) return null;

    var prog=gl.createProgram();
    gl.attachShader(prog,vs);gl.attachShader(prog,fs);gl.linkProgram(prog);
    if(!gl.getProgramParameter(prog,gl.LINK_STATUS)){console.error(gl.getProgramInfoLog(prog));return null;}
    gl.useProgram(prog);

    var buf=gl.createBuffer();
    gl.bindBuffer(gl.ARRAY_BUFFER,buf);
    gl.bufferData(gl.ARRAY_BUFFER,new Float32Array([-1,-1,1,-1,-1,1,1,1]),gl.STATIC_DRAW);
    var aPos=gl.getAttribLocation(prog,'a_pos');
    gl.enableVertexAttribArray(aPos);
    gl.vertexAttribPointer(aPos,2,gl.FLOAT,false,0,0);

    var uTime=gl.getUniformLocation(prog,'u_time');
    var uP=gl.getUniformLocation(prog,'u_p');
    var uP2=gl.getUniformLocation(prog,'u_p2');
    var uRes=gl.getUniformLocation(prog,'u_res');
    var uCol=gl.getUniformLocation(prog,'u_col');

    var rgb=(card.dataset.shaderColor||'1,1,1').split(',').map(Number);
    gl.uniform3f(uCol,rgb[0],rgb[1],rgb[2]);

    // u_p: arms, spiralDensity, direction, timeOffset
    var p1=(card.dataset.shaderP1||'5,12,1,0').split(',').map(Number);
    gl.uniform4f(uP,p1[0],p1[1],p1[2],p1[3]);
    // u_p2: ringFreq, ringSpeed, particleOrbit, glowSize
    var p2=(card.dataset.shaderP2||'20,3,0.12,5').split(',').map(Number);
    gl.uniform4f(uP2,p2[0],p2[1],p2[2],p2[3]);

    gl.enable(gl.BLEND);
    gl.blendFunc(gl.ONE,gl.ONE_MINUS_SRC_ALPHA);

    return {gl:gl,canvas:canvas,uTime:uTime,uRes:uRes};
  }

  function resize(s){
    var r=s.canvas.getBoundingClientRect();
    var dpr=Math.min(window.devicePixelRatio||1,2),sc=0.5;
    var w=Math.floor(r.width*dpr*sc),h=Math.floor(r.height*dpr*sc);
    if(w<1||h<1)return;
    s.canvas.width=w;s.canvas.height=h;
    s.gl.viewport(0,0,w,h);s.gl.uniform2f(s.uRes,w,h);
  }

  var cards=document.querySelectorAll('.net-card[data-shader]');
  var inst=[];
  cards.forEach(function(c){var s=initCard(c);if(s)inst.push(s);});
  if(!inst.length) return;

  function resizeAll(){inst.forEach(resize);}
  resizeAll();
  window.addEventListener('resize',resizeAll);

  var t0=performance.now();
  (function loop(){
    var t=(performance.now()-t0)*0.001;
    for(var i=0;i<inst.length;i++){
      var s=inst[i];
      s.gl.clearColor(0,0,0,0);s.gl.clear(s.gl.COLOR_BUFFER_BIT);
      s.gl.uniform1f(s.uTime,t);
      s.gl.drawArrays(s.gl.TRIANGLE_STRIP,0,4);
    }
    requestAnimationFrame(loop);
  })();
})();
</script>

</body>
</html>
