  title="Gateway"
  description="Bridge IP traffic to the Pilot Protocol overlay network — use curl, browsers, and any TCP tool."
  activePage="gateway"
  canonicalPath="/docs/gateway"
  prev={{ label: "Webhooks", href: "/docs/webhooks" }}
  next={{ label: "Tags & Discovery", href: "/docs/tags" }}
>
  <Fragment set:html={bodyContent} />
</DocLayout>
