<DocLayout
  title="Networks"
  description="Private networks in Pilot Protocol — group-level connectivity, membership permissions, join rules, and the security model."
  activePage="networks"
  canonicalPath="/docs/networks"
  prev={{ label: "Trust & Handshakes", href: "/docs/trust" }}
  next={{ label: "Built-in Services", href: "/docs/services" }}
>
  <Fragment set:html={bodyContent} />
