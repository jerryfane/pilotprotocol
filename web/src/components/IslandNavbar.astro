---
interface Props {
  active?: 'plans' | 'blog' | 'docs' | 'research' | 'home';
}

const { active } = Astro.props;
---
<style>
/* Navbar — glassmorphic floating island */
.navbar{position:fixed;top:16px;left:50%;transform:translateX(-50%);z-index:100;width:calc(100% - 48px);max-width:960px}
.nav-island{display:flex;align-items:center;gap:6px;padding:6px 8px;border-radius:16px;background:rgba(10,10,10,0.5);backdrop-filter:blur(24px);-webkit-backdrop-filter:blur(24px);border:1px solid rgba(255,255,255,0.08);box-shadow:0 4px 24px rgba(0,0,0,0.5),0 0 0 1px rgba(255,255,255,0.04) inset}
.nav-left{display:flex;align-items:center;gap:8px;text-decoration:none;padding:4px 12px 4px 6px;border-radius:40px;transition:background 0.2s}
.nav-left img{width:24px;height:24px}
.nav-left span{font-weight:700;font-size:0.88rem;color:var(--fg);white-space:nowrap}
.nav-left:hover{text-decoration:none;background:rgba(255,255,255,0.06)}
.nav-divider{width:1px;height:20px;background:rgba(255,255,255,0.1);margin:0 4px;flex-shrink:0}
.nav-center{display:flex;gap:2px;flex-shrink:0}
.nav-center a{font-size:0.82rem;color:var(--muted);transition:all 0.2s;padding:6px 14px;border-radius:40px;display:flex;align-items:center;gap:6px}
.nav-center a:hover{color:var(--fg);text-decoration:none;background:rgba(255,255,255,0.06)}
.nav-center a.active{color:var(--fg);font-weight:600;background:rgba(255,255,255,0.08)}
.nav-center a.active::before{content:'';display:inline-block;width:5px;height:5px;border-radius:50%;background:var(--accent);box-shadow:0 0 8px var(--accent);flex-shrink:0}
.nav-center a svg.nav-icon{width:14px;height:14px;stroke:currentColor;fill:none;stroke-width:1.5;stroke-linecap:round;stroke-linejoin:round;flex-shrink:0}
.nav-right{display:flex;align-items:center;gap:4px;margin-left:auto}
.nav-right .gh-link{color:var(--muted);transition:all 0.2s;display:flex;padding:6px 8px;border-radius:40px}
.nav-right .gh-link:hover{color:var(--fg);background:rgba(255,255,255,0.06)}
.nav-cta{font-size:0.8rem;padding:6px 16px;border-radius:40px;background:var(--accent);color:#000;font-weight:600;transition:all 0.2s;border:none;cursor:pointer;white-space:nowrap;text-decoration:none;display:inline-block}
.nav-cta:hover{opacity:0.9;text-decoration:none;box-shadow:0 0 16px rgba(34,197,94,0.3)}

/* Hamburger */
.nav-hamburger{display:none;background:none;border:none;color:var(--muted);cursor:pointer;padding:6px 8px;border-radius:40px;transition:all 0.2s;line-height:1}
.nav-hamburger:hover{color:var(--fg);background:rgba(255,255,255,0.06)}
.nav-hamburger svg{width:18px;height:18px;stroke:currentColor;fill:none;stroke-width:2;stroke-linecap:round;stroke-linejoin:round}

/* Mobile dropdown */
.nav-mobile{display:none;position:absolute;top:calc(100% + 8px);left:0;right:0;background:rgba(10,10,10,0.85);backdrop-filter:blur(24px);-webkit-backdrop-filter:blur(24px);border:1px solid rgba(255,255,255,0.08);border-radius:12px;padding:8px;box-shadow:0 8px 32px rgba(0,0,0,0.6)}
.nav-mobile.open{display:flex;flex-direction:column;gap:2px}
.nav-mobile a{font-size:0.85rem;color:var(--muted);padding:10px 16px;border-radius:8px;display:flex;align-items:center;gap:8px;transition:all 0.15s}
.nav-mobile a:hover{color:var(--fg);background:rgba(255,255,255,0.06);text-decoration:none}
.nav-mobile a svg{width:16px;height:16px;stroke:currentColor;fill:none;stroke-width:1.5;stroke-linecap:round;stroke-linejoin:round;flex-shrink:0}

/* Responsive — tablet (hide nav icons) */
@media(max-width:768px){
  .nav-center a svg.nav-icon{display:none}
  .nav-mobile a svg{display:none}
}

/* Responsive — phone */
@media(max-width:640px){
  .navbar{top:8px;left:8px;right:8px;transform:none;max-width:none;width:auto}
  .nav-island{width:100%;position:relative}
  .nav-center{display:none}
  .nav-divider{display:none}
  .nav-hamburger{display:block}
  .nav-right{margin-left:auto}
  .nav-cta{padding:5px 12px;font-size:0.78rem}
  .nav-left span{font-size:0.82rem}
}
</style>

<nav class="navbar">
  <div class="nav-island">
    <a class="nav-left" href="/">
      <img src="https://raw.githubusercontent.com/TeoSlayer/pilotprotocol/main/docs/media/pilot.png" alt="Pilot Protocol">
      <span>Pilot Protocol</span>
    </a>
    <div class="nav-divider"></div>
    <div class="nav-center">
      <a href="/docs/plans" class={active === 'plans' ? 'active' : ''}><svg class="nav-icon" viewBox="0 0 24 24"><path d="M12 2L2 7l10 5 10-5-10-5z"/><path d="M2 17l10 5 10-5"/><path d="M2 12l10 5 10-5"/></svg>Plans</a>
      <a href="/blog/" class={active === 'blog' ? 'active' : ''}>
        <svg class="nav-icon" viewBox="0 0 24 24"><path d="M12 20h9"/><path d="M16.5 3.5a2.121 2.121 0 0 1 3 3L7 19l-4 1 1-4z"/></svg>Blog
      </a>
    </div>
    <div class="nav-divider"></div>
    <div class="nav-center">
      <a href="/docs/" class={active === 'docs' ? 'active' : ''}>
        <svg class="nav-icon" viewBox="0 0 24 24"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/></svg>Docs
      </a>
      <a href="/docs/research" class={active === 'research' ? 'active' : ''}>
        <svg class="nav-icon" viewBox="0 0 24 24"><path d="M2 3h6a4 4 0 0 1 4 4v14a3 3 0 0 0-3-3H2z"/><path d="M22 3h-6a4 4 0 0 0-4 4v14a3 3 0 0 1 3-3h7z"/></svg>Research
      </a>
    </div>
    <div class="nav-right">
      <a class="gh-link" href="https://github.com/TeoSlayer/pilotprotocol" title="GitHub">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor"><path d="M12 0C5.37 0 0 5.37 0 12c0 5.31 3.435 9.795 8.205 11.385.6.105.825-.255.825-.57 0-.285-.015-1.23-.015-2.235-3.015.555-3.795-.735-4.035-1.41-.135-.345-.72-1.41-1.23-1.695-.42-.225-1.02-.78-.015-.795.945-.015 1.62.87 1.845 1.23 1.08 1.815 2.805 1.305 3.495.99.105-.78.42-1.305.765-1.605-2.67-.3-5.46-1.335-5.46-5.925 0-1.305.465-2.385 1.23-3.225-.12-.3-.54-1.53.12-3.18 0 0 1.005-.315 3.3 1.23.96-.27 1.98-.405 3-.405s2.04.135 3 .405c2.295-1.56 3.3-1.23 3.3-1.23.66 1.65.24 2.88.12 3.18.765.84 1.23 1.905 1.23 3.225 0 4.605-2.805 5.625-5.475 5.925.435.375.81 1.095.81 2.22 0 1.605-.015 2.895-.015 3.3 0 .315.225.69.825.57A12.02 12.02 0 0024 12c0-6.63-5.37-12-12-12z"/></svg>
      </a>
      <a class="nav-cta" href="/docs/getting-started">Get Started</a>
      <button class="nav-hamburger" onclick="document.querySelector('.nav-mobile').classList.toggle('open')" aria-label="Menu">
        <svg viewBox="0 0 24 24"><line x1="3" y1="6" x2="21" y2="6"/><line x1="3" y1="12" x2="21" y2="12"/><line x1="3" y1="18" x2="21" y2="18"/></svg>
      </button>
    </div>
    <div class="nav-mobile">
      <a href="/docs/plans"><svg viewBox="0 0 24 24"><path d="M12 2L2 7l10 5 10-5-10-5z"/><path d="M2 17l10 5 10-5"/><path d="M2 12l10 5 10-5"/></svg>Plans</a>
      <a href="/blog/"><svg viewBox="0 0 24 24"><path d="M12 20h9"/><path d="M16.5 3.5a2.121 2.121 0 0 1 3 3L7 19l-4 1 1-4z"/></svg>Blog</a>
      <a href="/docs/"><svg viewBox="0 0 24 24"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/></svg>Docs</a>
      <a href="/docs/research"><svg viewBox="0 0 24 24"><path d="M2 3h6a4 4 0 0 1 4 4v14a3 3 0 0 0-3-3H2z"/><path d="M22 3h-6a4 4 0 0 0-4 4v14a3 3 0 0 1 3-3h7z"/></svg>Research</a>
    </div>
  </div>
</nav>
